<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Educational Games menu under APEX root - visible only to APEX Teachers -->
    <menuitem id="educational_games_menu" name="Educational Games" parent="aps_sis.menu_apex_root" sequence="1020" groups="aps_sis.group_aps_teacher"/>

    <record id="educational_games_dashboard_action" model="ir.actions.act_url" forcecreate="1">
        <field name="name">Games Dashboard</field>
        <field name="url">/educational_games/dashboard</field>
        <field name="target">self</field>
    </record>

    <record id="action_student_game" model="ir.actions.client" forcecreate="1">
        <field name="name">Classroom Challenge</field>
        <field name="tag">action_student_game_js</field>
    </record>

    <record id="action_lonely_s_game" model="ir.actions.client" forcecreate="1">
        <field name="name">Lonely S</field>
        <field name="tag">action_lonely_s_game_js</field>
    </record>

    <!-- Menu items for each quiz/game -->
    <menuitem id="menu_lonely_s_game" name="Lonely S" parent="educational_games_menu" action="action_lonely_s_game" sequence="10" groups="aps_sis.group_aps_teacher"/>

    <menuitem id="menu_binary_conversions" name="Binary Conversions" parent="educational_games_menu" action="action_binary_conversions" sequence="20" groups="aps_sis.group_aps_teacher"/>

    <menuitem id="menu_binary_adder_original" name="Binary Adder" parent="educational_games_menu" action="action_binary_adder_original" sequence="40" groups="aps_sis.group_aps_teacher"/>

    <menuitem id="menu_student_game" name="Classroom Challenge" parent="educational_games_menu" action="action_student_game" sequence="50" groups="aps_sis.group_aps_teacher"/>

    <!-- Quiz sub-menu -->
    <menuitem id="menu_quiz_admin" name="Quizzes" parent="educational_games_menu" action="action_quiz_list" sequence="60" groups="aps_sis.group_aps_teacher"/>
</odoo>