<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Back-end: list + form views for quiz administration -->
    <record id="action_quiz_list" model="ir.actions.act_window">
        <field name="name">Quizzes</field>
        <field name="res_model">quiz.quiz</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Client action: student quiz game (OWL component) -->
    <record id="action_quiz_game" model="ir.actions.client">
        <field name="name">Quiz</field>
        <field name="tag">action_quiz_game_js</field>
    </record>

</odoo>
