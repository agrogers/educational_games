<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         quiz.quiz  –  List view
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_quiz_list" model="ir.ui.view">
        <field name="name">quiz.quiz.list</field>
        <field name="model">quiz.quiz</field>
        <field name="arch" type="xml">
            <list string="Quizzes">
                <field name="name"/>
                <field name="question_count"/>
                <field name="total_marks"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         quiz.quiz  –  Form view  (questions + answers on one page)
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_quiz_form" model="ir.ui.view">
        <field name="name">quiz.quiz.form</field>
        <field name="model">quiz.quiz</field>
        <field name="arch" type="xml">
            <form string="Quiz">
                <header>
                    <button name="action_preview_quiz"
                            string="Preview Quiz"
                            type="object"
                            class="btn btn-secondary"
                            icon="fa-eye"/>
                    <button name="action_delete_all_questions"
                            string="Delete All Questions"
                            type="object"
                            class="btn btn-danger"
                            icon="fa-trash"
                            confirm="This will permanently delete ALL questions and answers for this quiz. This cannot be undone. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Quiz Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Business English – Formal Letters"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="question_count" readonly="1"/>
                            <field name="total_marks" readonly="1"/>
                        </group>
                        <group class="quiz-form-header-image">
                            <field name="header_image" widget="image"
                                   string="Header Image"
                                   options="{'size': [800, 200]}"
                                   nolabel="1"/>
                        </group>
                    </group>
                    <field name="description" widget="html"
                           placeholder="Optional description shown to students…"/>

                    <notebook>
                        <!-- ── Questions tab ── -->
                        <page string="Questions" name="questions">
                            <field name="question_ids" context="{'default_quiz_id': id}">
                                <list string="Questions">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question_text" widget="html" string="Question"/>
                                    <field name="marks"/>
                                    <field name="correct_answer_count" string="# Correct"/>
                                </list>
                                <!-- Inline popup form: question + all its answers on one page -->
                                <form string="Question">
                                    <sheet>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="marks"/>
                                            <field name="allow_multiple"/>
                                        </group>
                                        <field name="question_text" widget="html"
                                               placeholder="Enter the question…"/>
                                        <separator string="Answers"/>
                                        <field name="answer_ids">
                                            <list editable="bottom" string="Answers">
                                                <field name="sequence" widget="handle"/>
                                                <field name="answer_text" widget="html"
                                                       string="Answer Text"/>
                                                <field name="is_correct" string="Correct?"/>
                                            </list>
                                        </field>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <!-- ── Bulk import tab ── -->
                        <page string="Bulk Import" name="bulk_import">
                            <div class="alert alert-info" role="alert">
                                <strong>Recommended workflow:</strong>
                                <ol class="mb-1 mt-1">
                                    <li>Paste your quiz text into the field below.</li>
                                    <li>Click <strong>Clean Up Text</strong> to fix Unicode/formatting artefacts from ChatGPT or NotebookLM.</li>
                                    <li>Click <strong>Preview Import</strong> to colour-code the text:
                                        <span style="color:#1e1b4b; font-weight:bold;"> dark = question</span>,
                                        <span style="color:#15803d; font-weight:bold;"> green = correct answer</span>,
                                        <span style="color:#9a3412;"> red = answer option</span>,
                                        <span style="color:#9ca3af;"> grey = unrecognised</span>.
                                    </li>
                                    <li>Edit the colour-coded text if needed, then click <strong>Import Questions from Text</strong>.</li>
                                </ol>
                                <strong>Supported paste formats:</strong>
                                <ul class="mb-1">
                                    <li><em>Italic</em> question line + plain answer lines + <strong>bold correct answer</strong> (Method 1).</li>
                                    <li>Numbered questions (<code>1. text</code>) + lettered answers (<code>A) text</code>) with the correct answer in <strong>bold</strong> (Method 2 — ChatGPT default).</li>
                                </ul>
                                <small class="text-muted">
                                    Prefixes like "Question 1:" and "A." are automatically removed on import.
                                    The text is kept in this field after import so you can review or re-import.
                                </small>
                            </div>
                            <field name="bulk_text" widget="html"
                                   placeholder="Paste your formatted quiz text here…"/>
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                <button name="action_cleanup_bulk_text"
                                        string="1. Clean Up Text"
                                        type="object"
                                        class="btn btn-secondary"
                                        icon="fa-magic"/>
                                <button name="action_preview_bulk_text"
                                        string="2. Preview Import"
                                        type="object"
                                        class="btn btn-info"
                                        icon="fa-eye"/>
                                <button name="action_parse_bulk_text"
                                        string="3. Import Questions from Text"
                                        type="object"
                                        class="btn btn-primary"
                                        icon="fa-upload"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bind specific views to the quiz list action -->
    <record id="action_quiz_list_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_quiz_quiz_list"/>
        <field name="act_window_id" ref="educational_games.action_quiz_list"/>
    </record>

    <record id="action_quiz_list_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_quiz_quiz_form"/>
        <field name="act_window_id" ref="educational_games.action_quiz_list"/>
    </record>

</odoo>
