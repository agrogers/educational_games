<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         quiz.quiz  –  List view
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_quiz_list" model="ir.ui.view">
        <field name="name">quiz.quiz.list</field>
        <field name="model">quiz.quiz</field>
        <field name="arch" type="xml">
            <list string="Quizzes">
                <field name="name"/>
                <field name="subject_ids" widget="many2many_tags" optional="show"/>
                <field name="question_count"/>
                <field name="total_marks"/>
                <field name="create_date" string="Created" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_quiz_quiz_search" model="ir.ui.view">
        <field name="name">quiz.quiz.search</field>
        <field name="model">quiz.quiz</field>
        <field name="arch" type="xml">
            <search string="Search Quizzes">
                <field name="name"/>
                <field name="subject_ids"/>
                <field name="filter_tag_ids"/>
                <group expand="0" string="Group By">
                    <filter string="Subject" name="group_by_subject" context="{'group_by': 'subject_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         quiz.quiz  –  Form view  (questions + answers on one page)
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_quiz_form" model="ir.ui.view">
        <field name="name">quiz.quiz.form</field>
        <field name="model">quiz.quiz</field>
        <field name="arch" type="xml">
            <form string="Quiz">
                <header>
                    <button name="action_preview_quiz"
                            string="Preview Quiz"
                            type="object"
                            class="btn btn-secondary"
                            icon="fa-eye"/>
                    <button name="action_delete_all_questions"
                            string="Delete All Questions"
                            type="object"
                            class="btn btn-danger"
                            icon="fa-trash"
                            confirm="This will permanently delete ALL questions and answers for this quiz. This cannot be undone. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Quiz Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Business English – Formal Letters"/>
                        </h1>
                    </div>

                    <notebook>
                        <page string="Settings" name="settings">
                            <group>
                                <group string="Display Settings">
                                    <field name="question_count" readonly="1"/>
                                    <field name="total_marks" readonly="1"/>
                                    <field name="subject_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="display_question_count"/>
                                    <field name="display_option_count"/>
                                    <field name="allow_resubmission"/>
                                </group>
                                <group class="quiz-form-header-image">
                                    <field name="header_image" widget="image"
                                           string="Header Image"
                                           options="{'size': [400, 50]}"
                                           nolabel="1"/>
                                </group>
                            </group>
                            <group string="Question Filters">
                                <group>
                                    <field name="filter_tag_ids" widget="many2many_tags"
                                           options="{'no_create': False}"
                                           placeholder="Any matching tags..."/>
                                    <field name="filter_subject_ids" widget="many2many_tags"
                                           options="{'no_create': True}"
                                           placeholder="Any matching subjects..."/>
                                    <field name="filter_min_attempts" placeholder="Leave empty to ignore"/>
                                    <field name="filter_max_attempts" placeholder="Leave empty to ignore"/>
                                </group>
                                <group>
                                    <field name="filter_max_pct_correct" placeholder="Leave empty to ignore"/>
                                    <field name="filter_student_attempts" placeholder="Leave empty to ignore"/>
                                    <field name="filter_student_weighted_score_pct" placeholder="Leave empty to ignore"/>
                                </group>
                            </group>
                            <group>
                                <field name="quiz_url_params" readonly="1"
                                       string="APEX Game URL"
                                       widget="CopyClipboardChar"
                                       help="Paste this into the resource URL field in APEX to open this quiz. The format is action:&lt;id&gt;?quiz_id=&lt;id&gt;&amp;… matching the pattern used by other games."/>
                            </group>
                            <field name="description" widget="html"
                                   placeholder="Optional description shown to students…"/>
                        </page>
                        <!-- ── Questions tab ── -->
                        <page string="Questions" name="questions">
                            <div class="mb-2">
                                <button name="%(educational_games.action_quiz_question_list)d"
                                        string="Open Questions List"
                                        type="action"
                                        class="btn btn-secondary"
                                        icon="fa-external-link"
                                        context="{'search_default_all_quiz_ids': id}"/>
                            </div>
                            <field name="question_ids" context="{'default_quiz_id': id}">
                                <list string="Questions">
                                    <field name="id" string="ID" optional="show"/>
                                    <field name="sequence" widget="handle" optional="hide"/>
                                    <field name="question_text" widget="html" string="Question" optional="hide"/>
                                    <field name="correct_answer" widget="html" optional="hide"/>
                                    <field name="marks" optional="hide"/>
                                    <field name="import_group" optional="hide"/>
                                    <field name="subject_ids" widget="many2many_tags" optional="show"/>
                                    <field name="tag_ids" widget="many2many_tags" optional="show"/>
                                    <field name="correct_answer_count" string="Correct Options" optional="hide"/>
                                    <field name="attempt_count" string="Attempts" optional="show"/>
                                    <field name="pct_correct_all" string="% Correct" optional="show"/>
                                    <field name="pct_correct_recent" string="% Correct (1h)" optional="hide"/>
                                    <field name="create_date" string="Created" optional="show"/>
                                </list>
                                <!-- Inline popup form: question + all its answers on one page -->
                                <form string="Question">
                                    <sheet>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="marks"/>
                                            <field name="allow_multiple"/>
                                            <field name="import_group"/>
                                            <field name="subject_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                            <field name="tag_ids" widget="many2many_tags"/>
                                        </group>
                                        <field name="question_text" widget="html"
                                               placeholder="Enter the question…"/>
                                        <separator string="Answers"/>
                                        <field name="answer_ids">
                                            <list editable="bottom" string="Answers">
                                                <field name="sequence" widget="handle" optional="hide"/>
                                                <field name="answer_text" widget="html"
                                                       string="Answer Text" optional="hide"/>
                                                <field name="is_correct" string="Correct?" optional="hide"/>
                                                <field name="select_count" string="Selected" optional="show"/>
                                                <field name="select_pct_all" string="% (All)" optional="show"/>
                                                <field name="select_pct_recent" string="% (1h)" optional="hide"/>
                                                <field name="create_date" string="Created" optional="show"/>
                                            </list>
                                        </field>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Bulk Add" name="bulk_add">
                            <div class="alert alert-info" role="alert">
                                <strong>Bulk Add by Question ID:</strong>
                                <p class="mb-1 mt-1">Paste IDs separated by commas, spaces, or new lines. Click <strong>Check</strong> to stage questions, remove unwanted rows, then click <strong>Add Questions</strong>.</p>
                            </div>
                            <group>
                                <field name="bulk_add_question_ids_text" placeholder="Example: 12, 15 21 34"/>
                            </group>
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                <button name="action_bulk_check_question_ids"
                                        string="Check"
                                        type="object"
                                        class="btn btn-secondary"
                                        icon="fa-check"/>
                                <button name="action_bulk_add_questions"
                                        string="Add Questions"
                                        type="object"
                                        class="btn btn-primary"
                                        icon="fa-plus"/>
                            </div>
                            <field name="bulk_add_question_ids">
                                <list string="Staged Questions" create="0" delete="1" editable="bottom">
                                    <field name="id"/>
                                    <field name="question_text" widget="html" optional="show"/>
                                    <field name="correct_answer" widget="html" optional="show"/>
                                    <field name="subject_ids" widget="many2many_tags" optional="show"/>
                                    <field name="tag_ids" widget="many2many_tags" optional="show"/>
                                    <field name="import_group" optional="show"/>
                                    <field name="marks" optional="show"/>
                                    <field name="create_date" string="Created" optional="show"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bind specific views to the quiz list action -->
    <record id="action_quiz_list_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_quiz_quiz_list"/>
        <field name="act_window_id" ref="educational_games.action_quiz_list"/>
    </record>

    <record id="action_quiz_list_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_quiz_quiz_form"/>
        <field name="act_window_id" ref="educational_games.action_quiz_list"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         quiz.tag  –  List view
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_tag_list" model="ir.ui.view">
        <field name="name">quiz.tag.list</field>
        <field name="model">quiz.tag</field>
        <field name="arch" type="xml">
            <list string="Question Tags">
                <field name="name"/>
                <field name="description" optional="show"/>
                <field name="create_date" string="Created" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_quiz_tag_form" model="ir.ui.view">
        <field name="name">quiz.tag.form</field>
        <field name="model">quiz.tag</field>
        <field name="arch" type="xml">
            <form string="Question Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         quiz.question  –  Standalone list view
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_question_list" model="ir.ui.view">
        <field name="name">quiz.question.list</field>
        <field name="model">quiz.question</field>
        <field name="arch" type="xml">
            <list string="Questions" multi_edit="1">
                <header>
                    <button name="action_open_tag_wizard" string="Bulk Modify" type="object" icon="fa-pencil"/>
                </header>
                <field name="id" string="ID" optional="show"/>
                <field name="quiz_id" optional="hide"/>
                <field name="sequence" widget="handle" optional="hide"/>
                <field name="question_text" widget="html" optional="hide"/>
                <field name="correct_answer" widget="html" optional="hide"/>
                <field name="marks" optional="hide"/>
                <field name="import_group" optional="show"/>
                <field name="subject_ids" widget="many2many_tags" optional="show"/>
                <field name="tag_ids" widget="many2many_tags" optional="show"/>
                <field name="create_date" string="Created" optional="show"/>
                <field name="correct_answer_count" string="Correct Options" optional="hide"/>
                <field name="attempt_count" string="Attempts" optional="show"/>
                <field name="pct_correct_all" string="% Correct" optional="show"/>
                <field name="pct_correct_recent" string="% Correct (1h)" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_quiz_question_search" model="ir.ui.view">
        <field name="name">quiz.question.search</field>
        <field name="model">quiz.question</field>
        <field name="arch" type="xml">
            <search string="Search Questions">
                <field name="question_text" string="Question"/>
                <field name="correct_answer" string="Correct Answer"/>
                <field name="quiz_id"/>
                <field name="all_quiz_ids" string="Quiz"/>
                <field name="import_group"/>
                <field name="subject_ids"/>
                <field name="tag_ids"/>
                <filter string="Multiple Answers" name="filter_multiple" domain="[('allow_multiple', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Quiz" name="group_by_quiz" context="{'group_by': 'quiz_id'}"/>
                    <filter string="Import Group" name="group_by_import_group" context="{'group_by': 'import_group'}"/>
                    <filter string="Subject" name="group_by_subject" context="{'group_by': 'subject_ids'}"/>
                    <filter string="Tags" name="group_by_tags" context="{'group_by': 'tag_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         quiz.question  –  Standalone form view
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_question_form" model="ir.ui.view">
        <field name="name">quiz.question.form</field>
        <field name="model">quiz.question</field>
        <field name="arch" type="xml">
            <form string="Question">
                <sheet>
                    <group>
                        <group>
                            <field name="quiz_id" string="Primary Quiz"/>
                            <field name="sequence"/>
                            <field name="marks"/>
                            <field name="allow_multiple"/>
                            <field name="import_group"/>
                            <field name="subject_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'no_create': False}"/>
                        </group>
                        <group>
                            <field name="correct_answer_count" readonly="1" string="Correct Options"/>
                            <field name="correct_answer" readonly="1" widget="html"/>
                            <field name="attempt_count" readonly="1" string="Attempts"/>
                            <field name="pct_correct_all" readonly="1" string="% Correct (All)"/>
                            <field name="pct_correct_recent" readonly="1" string="% Correct (1h)"/>
                        </group>
                    </group>
                    <field name="question_text" widget="html" placeholder="Enter the question…"/>
                    <group>
                        <field name="all_quiz_ids" widget="many2many_tags" options="{'no_create': True}"
                               help="All quizzes this question belongs to."/>
                    </group>
                    <separator string="Answers"/>
                    <field name="answer_ids">
                        <list editable="bottom" string="Answers">
                            <field name="sequence" widget="handle"/>
                            <field name="answer_text" widget="html" string="Answer Text"/>
                            <field name="is_correct" string="Correct?"/>
                            <field name="create_date" string="Created" readonly="1" optional="show"/>
                            <field name="select_count" readonly="1" string="Selected" optional="show"/>
                            <field name="select_pct_all" readonly="1" string="% (All)" optional="show"/>
                            <field name="select_pct_recent" readonly="1" string="% (1h)" optional="hide"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_quiz_question_import_wizard_form" model="ir.ui.view">
        <field name="name">quiz.question.import.wizard.form</field>
        <field name="model">quiz.question.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Quiz Questions Import">
                <sheet>
                <div class="d-flex flex-wrap gap-2 align-items-center sticky-top bg-white pt-2 pb-2 mb-3 border-bottom">
                <button name="action_cleanup_bulk_text"
                    string="1. Clean Up Text"
                    type="object"
                    class="btn btn-secondary"
                    icon="fa-magic"/>
                <button name="action_preview_bulk_text"
                    string="2. Preview Import"
                    type="object"
                    class="btn btn-info"
                    icon="fa-eye"/>
                <button name="action_import_questions"
                    string="3. Import Questions from Text"
                    type="object"
                    class="btn btn-primary"
                    icon="fa-upload"/>
                </div>
                    <div class="alert alert-info" role="alert">
                        <strong>Import workflow:</strong>
                        <ol class="mb-1 mt-1">
                            <li>Set an Import Group and optional Subjects/Tags to apply to all imported questions.</li>
                            <li>Paste your quiz text in the field below.</li>
                            <li>Click <strong>Clean Up Text</strong> then <strong>Preview Import</strong>.</li>
                            <li>Click <strong>Import Questions from Text</strong> to create unattached question records.</li>
                        </ol>
                    </div>
                    <group>
                        <group>
                            <field name="import_group"/>
                            <field name="subject_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'no_create': False}"/>
                        </group>
                    </group>
                    <field name="bulk_text" widget="html" placeholder="Paste your formatted quiz text here…"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Wizard: Bulk Modify Questions
    ═══════════════════════════════════════════════════════ -->
    <record id="view_quiz_question_tag_wizard_form" model="ir.ui.view">
        <field name="name">quiz.question.tag.wizard.form</field>
        <field name="model">quiz.question.tag.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Modify Questions">
                <sheet>
                    <notebook>
                        <page string="Options">
                            <group col="12">
                                <group string="Update which fields" col="12" colspan="8">
                                    <group colspan="4">
                                        <field name="update_tags" nolabel="1" widget="boolean_toggle"/>
                                        <label for="update_tags" class="mb-0">Tags</label>
                                    </group>
                                    <group colspan="8" invisible="not update_tags">
                                        <field name="tags_add_ids" widget="many2many_tags" string="Add" placeholder="Tags to add..." options="{'no_create': False}"/>
                                        <field name="tags_remove_ids" widget="many2many_tags" string="Remove" placeholder="Tags to remove..." options="{'no_create': False}"/>
                                    </group>

                                    <group colspan="4">
                                        <field name="update_subjects" nolabel="1" widget="boolean_toggle"/>
                                        <label for="update_subjects" class="mb-0">Subjects</label>
                                    </group>
                                    <group colspan="8" invisible="not update_subjects">
                                        <field name="subjects_add_ids" widget="many2many_tags" string="Add" placeholder="Subjects to add..." options="{'no_create': True}"/>
                                        <field name="subjects_remove_ids" widget="many2many_tags" string="Remove" placeholder="Subjects to remove..." options="{'no_create': True}"/>
                                    </group>
                                </group>
                                <group string="Questions to Update" colspan="4">
                                    <field name="question_ids" widget="many2many_tags" nolabel="1" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="apply_changes" string="Apply" type="object" class="btn btn-primary"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
