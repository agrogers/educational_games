<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="binary_conversions.GameTemplate" owl="1">
        <div class="o_action_manager o_content p-5 bg-light h-100 overflow-auto">
            <div class="card shadow-sm mx-auto" style="max-width: 900px;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">Binary Conversions</h3>
                    <span class="badge bg-light text-dark">Timer: <t t-esc="this.formatTime(state.timer_seconds)"/></span>
                </div>
                <div class="card-body">
                    <div t-if="!state.started" class="mb-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Type of conversion</label>
                                <select class="form-select" t-model="state.conversion_type">
                                    <option value="bin_to_dec">Binary to Decimal</option>
                                    <option value="dec_to_bin">Decimal to Binary</option>
                                    <option value="bin_to_hex">Binary to Hexadecimal</option>
                                    <option value="hex_to_bin">Hexadecimal to Binary</option>
                                    <option value="dec_to_hex">Decimal to Hexadecimal</option>
                                    <option value="hex_to_dec">Hexadecimal to Decimal</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Size of numbers</label>
                                <input type="number" class="form-control" min="1" max="16" t-model="state.number_size"/>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Number of questions</label>
                                <input type="number" class="form-control" min="1" max="50" t-model="state.num_questions"/>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-success" t-on-click="startQuiz">Start Quiz</button>
                        </div>
                    </div>

                    <div t-if="state.started">
                        <div t-foreach="state.questions" t-as="item" t-key="item.uniqueId" class="p-3 border-bottom">
                            <p class="fs-5">
                                <span t-attf-class="{{state.checked and !item.isCorrect and 'text-danger fw-bold' or ''}}">
                                    <t t-esc="item.prompt"/>
                                </span>
                            </p>
                            <div class="d-flex align-items-center">
                                <input type="text"
                                       class="form-control w-50"
                                       placeholder="Type your answer..."
                                       t-model="item.userAnswer"
                                       t-att-disabled="state.checked"/>
                                <span t-if="state.checked" class="ms-3">
                                    <t t-if="item.isCorrect">
                                        <span class="text-success fs-4">✅</span>
                                    </t>
                                    <t t-else="">
                                        <span class="text-danger">❌ Correct: <strong t-esc="item.correctAnswer"/></span>
                                    </t>
                                </span>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <h4 t-if="state.checked" class="mb-3">
                                Final Score: <strong><t t-esc="state.score"/></strong> out of <t t-esc="state.questions.length"/>
                            </h4>
                            <h5 t-if="state.checked and state.submission_submitted" class="mb-3">
                                These results have been saved and the APEX task submitted.
                            </h5>
                            <button t-if="!state.checked" class="btn btn-lg btn-success" t-on-click="checkAnswers">
                                Check Answers
                            </button>
                            <button t-if="state.checked" class="btn btn-lg btn-outline-primary" t-on-click="resetGame">
                                Try Again
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
